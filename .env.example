# 复制为 .env 后按需修改；不要将真实 .env 提交到版本库。

# 监听地址：仅本机可填 127.0.0.1；需局域网访问可填 0.0.0.0
HOST=0.0.0.0
PORT=8765

# Session 签名密钥（请替换为随机字符串）
SECRET_KEY=change-me-use-openssl-rand-hex-32

# SQLite 路径（相对于项目根目录）
DATABASE_PATH=data/app.db

# 上传大小上限（字节），默认 15MB
MAX_UPLOAD_BYTES=15728640

# 参考样式文件名（放在 data/reference_samples/ 目录下）；含空格时请用双引号包住
REFERENCE_STYLE_DOCX="Research Paper Generation Request.docx"

# GitHub 发布（仅服务端；勿泄露）
GITHUB_TOKEN=
GITHUB_REPO=ilovezmw/researchPaper
GITHUB_PUBLISH_PREFIX=published/

# 可选：源稿标题与摘要/Executive Summary 之间没有作者行时，格式化输出仍显示署名（三行）
# AUTHOR_LINE_1="Mingwei Zhang"
# AUTHOR_LINE_2="Independent Researcher, Singapore"
# AUTHOR_LINE_3="March 2026"
